@model DailyRoutineApp.Models.Routine

@{
	Layout = "~/Views/Shared/_Layout.cshtml";
}

<h1>Edit Routine</h1>

<form method="post" class="row g-3">

  <input type="hidden" name="Id" value="@Model.Id" />

  <div class="col-md-6">

	<label class="form-label">Title</label>

	<input name="Title" class="form-control" value="@Model.Title" />

  </div>

  <div class="col-md-3">

	<label class="form-label">Date</label>

	<input type="date" name="Date" class="form-control" value="@Model.Date.ToString("yyyy-MM-dd")" />

  </div>

  <div class="col-12">

	<label class="form-label">Notes</label>

	<textarea name="Notes" class="form-control" rows="2">@Model.Notes</textarea>

  </div>

  <hr />

  <h4>Activities (up to 6)</h4>

@for (int i = 0; i < 6; i++) {

	var act = Model.Activities.Count > i ? Model.Activities[i] : new DailyRoutineApp.Models.Activity();

	<div class="border rounded p-3 mb-2">

		<div class="row g-2">

			<div class="col-md-5">

				<label class="form-label">Name</label>

				<input name="Activities[@i].Name" class="form-control" value="@act.Name" />

			</div>

			<div class="col-md-2">

				<label class="form-label">Time</label>

				<input type="time" name="Activities[@i].Time" class="form-control" value="@(act.Time == default ? string.Empty : act.Time.ToString("hh\\:mm"))" />

			</div>

			<div class="col-md-2">

				<label class="form-label">Duration (min)</label>

				<input type="number" name="Activities[@i].DurationMinutes" class="form-control" value="@(act.DurationMinutes)" />

			</div>

			<div class="col-md-3">

				<label class="form-label">Notes</label>

				<input name="Activities[@i].Notes" class="form-control" value="@act.Notes" />

			</div>

		</div>

	</div>

}

	<div class="col-12">

		<button type="submit" class="btn btn-success">Save Changes</button>

		<a class="btn btn-secondary" href="/Routine/Details/@Model.Id">Cancel</a>

	</div>

</form>
